{
  "git": {
    "deploymentEnabled": {
      "dev": false,
      "preview": false,
      "main": true
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mastergrowbot.lovable.app"
        }
      ],
      "destination": "https://www.mastergrowbot.lovable.app/:path*",
      "permanent": true
    }
  ]
}